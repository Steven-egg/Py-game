{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "registry.schema.json",
  "title": "Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_type", "registry_version", "entries"],
  "properties": {
    "registry_type": {
      "type": "string",
      "minLength": 1
    },
    "registry_version": {
      "type": "string",
      "const": "1.4.0"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/registry_entry"
      }
    }
  },
  "$defs": {
    "registry_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "canonical_name",
        "domain",
        "status",
        "reason",
        "source_layer"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "enum": [
            "effect",
            "condition",
            "quest",
            "item",
            "monster",
            "event",
            "flag",
            "save",
            "content_manifest",
            "registry"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "allowed",
            "blocked",
            "deprecated",
            "experimental"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_layer": {
          "type": "string",
          "enum": [
            "schema_contract",
            "governance_metadata",
            "engine_internal",
            "legacy_engine_mapping",
            "content_reference",
            "external_reference"
          ]
        },
        "notes": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "replaced_by": {
          "type": "string",
          "minLength": 1
        },
        "coverage_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "behavior"],
          "properties": {
            "schema": {
              "type": "boolean"
            },
            "behavior": {
              "type": "boolean"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "blocked"
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["coverage_gate"],
            "properties": {
              "coverage_gate": {
                "properties": {
                  "schema": {
                    "const": false
                  },
                  "behavior": {
                    "const": false
                  }
                },
                "required": ["schema", "behavior"]
              }
            }
          }
        }
      ]
    }
  }
}
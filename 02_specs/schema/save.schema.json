{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "save.schema.json",
  "title": "Save File Schema (save@1.0)",
  "$comment": "Engine 1.0.0 | Spec 1.3.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "save_schema",
    "engine_version",
    "content_manifest_hash",
    "active_quest",
    "game_state",
    "completed_ids"
  ],
  "properties": {
    "save_schema": {
      "const": "save@1.0"
    },

    "engine_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "content_manifest_hash": {
      "type": "string",
      "minLength": 8
    },

    "active_quest": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["quest_id", "accepted_at", "progress", "completed_at"],
          "properties": {
            "quest_id": {
              "type": "string",
              "minLength": 1
            },
            "accepted_at": {
              "type": "string",
              "minLength": 1
            },
            "progress": {
              "type": "object"
            },
            "completed_at": {
              "type": ["string", "null"]
            }
          }
        }
      ]
    },

    "game_state": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "flags": {
          "type": "object",
          "default": {}
        },
        "inventory": {
          "type": "object",
          "default": {}
        },
        "vars": {
          "type": "object",
          "default": {}
        },
        "current_location": {
          "type": "string",
          "default": "start_village",
          "description": "Persistent current location for Phase D.2. Engine writes this field; runtime_context mirrors it during session."
        }
      },
      "required": ["flags", "inventory", "vars"]
    },

    "completed_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  }
}
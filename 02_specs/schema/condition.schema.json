{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "condition.schema.json",
  "title": "Condition Schema (cond@1.0)",
  "$comment": "Engine 1.0.0 | Spec 1.2.0 | Structure 1.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "params"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "flag.is_true",
        "flag.is_false",
        "flag.int_compare",
        "stat.compare",
        "inventory.has",
        "gold.compare",
        "and",
        "or",
        "not"
      ]
    },
    "params": {
      "type": "object"
    }
  },

  "allOf": [

    {
      "if": { "properties": { "type": { "const": "flag.is_true" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key"],
            "properties": {
              "key": { "$ref": "common.schema.json#/$defs/FlagKey" }
            }
          }
        }
      }
    },

    {
      "if": { "properties": { "type": { "const": "flag.int_compare" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "op", "value"],
            "properties": {
              "key": { "$ref": "common.schema.json#/$defs/FlagKey" },
              "op": { "enum": ["eq", "gt", "gte", "lt", "lte"] },
              "value": { "type": "integer" }
            }
          }
        }
      }
    },

    {
      "if": { "properties": { "type": { "const": "stat.compare" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stat", "op", "value"],
            "properties": {
              "stat": { "type": "string" },
              "op": { "enum": ["eq", "gt", "gte", "lt", "lte"] },
              "value": { "type": ["integer", "number"] }
            }
          }
        }
      }
    },

    {
      "if": { "properties": { "type": { "const": "inventory.has" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item_id", "qty"],
            "properties": {
              "item_id": { "$ref": "common.schema.json#/$defs/Id" },
              "qty": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },

    {
      "if": { "properties": { "type": { "const": "and" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": ["conditions"],
            "additionalProperties": false,
            "properties": {
              "conditions": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#" }
              }
            }
          }
        }
      }
    },

    {
      "if": { "properties": { "type": { "const": "not" } } },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "required": ["condition"],
            "additionalProperties": false,
            "properties": {
              "condition": { "$ref": "#" }
            }
          }
        }
      }
    }

  ]
}
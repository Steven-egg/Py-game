{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "monster.schema.json",
  "title": "Monster Schema (monster@1.0)",
  "$comment": "Engine 1.0.0 | Spec 1.2.0 | Structure 1.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "name", "stats", "rewards"],
  "properties": {
    "schema": { "const": "monster@1.0" },

    "id": {
      "allOf": [
        { "$ref": "common.schema.json#/$defs/Id" },
        { "pattern": "^m\\.[a-z0-9_]+(\\.[a-z0-9_]+)*$" }
      ]
    },

    "name": { "$ref": "common.schema.json#/$defs/TextKey" },
    "desc": { "$ref": "common.schema.json#/$defs/TextKey" },

    "tags": { "$ref": "common.schema.json#/$defs/Tags" },

    "tier": {
      "type": "string",
      "enum": ["normal", "elite", "boss"],
      "default": "normal"
    },

    "level": { "type": "integer", "minimum": 1, "default": 1 },

    "spawn_condition": {
      "$comment": "Optional: If present, the monster is valid only when condition evaluates true",
      "$ref": "condition.schema.json"
    },

    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hp", "atk", "def", "agi"],
      "properties": {
        "hp": { "type": "integer", "minimum": 1 },
        "atk": { "type": "integer", "minimum": 0 },
        "def": { "type": "integer", "minimum": 0 },
        "agi": { "type": "integer", "minimum": 0 },

        "crit_rate": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
        "hit_rate": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "evade_rate": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 }
      }
    },

    "resists": {
      "$comment": "Optional: simple resistance table; semantics handled by battle module",
      "type": "object",
      "additionalProperties": { "type": "number" },
      "default": {}
    },

    "ai": {
      "$comment": "v1 minimal: weighted actions; battle module interprets",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "weight"],
            "properties": {
              "id": {
                "type": "string",
                "enum": ["attack", "defend", "skill", "escape_attempt"]
              },
              "weight": { "type": "integer", "minimum": 1 },

              "condition": {
                "$comment": "Optional: action available only when condition is true",
                "$ref": "condition.schema.json"
              },

              "skill_id": {
                "$comment": "Optional: only when id=skill",
                "allOf": [
                  { "$ref": "common.schema.json#/$defs/Id" },
                  { "pattern": "^sk\\.[a-z0-9_]+(\\.[a-z0-9_]+)*$" }
                ]
              }
            }
          }
        }
      },
      "default": { "actions": [{ "id": "attack", "weight": 1 }] }
    },

    "rewards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exp", "gold"],
      "properties": {
        "exp": { "type": "integer", "minimum": 0 },
        "gold": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 0 },
            "max": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "drops": {
      "$comment": "Optional drop table; use weights; actual roll is via loot.roll at runtime",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "table_id": {
          "allOf": [
            { "$ref": "common.schema.json#/$defs/Id" },
            { "pattern": "^loot\\.[a-z0-9_]+(\\.[a-z0-9_]+)*$" }
          ]
        },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/DropEntry" },
          "default": []
        }
      },
      "default": { "entries": [] }
    },

    "hooks": {
      "$comment": "Optional: effects emitted by battle module on key moments (still enforced by effect.schema)",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on_encounter": {
          "type": "array",
          "items": { "$ref": "effect.schema.json" },
          "default": []
        },
        "on_defeat": {
          "type": "array",
          "items": { "$ref": "effect.schema.json" },
          "default": []
        },
        "on_hit": {
          "$comment": "Optional: emitted when this monster hits the player (battle module decides timing)",
          "type": "array",
          "items": { "$ref": "effect.schema.json" },
          "default": []
        }
      },
      "default": {}
    }
  },

  "$defs": {
    "DropEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "weight", "qty"],
      "properties": {
        "item_id": { "$ref": "common.schema.json#/$defs/Id" },
        "weight": { "type": "integer", "minimum": 1 },
        "qty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          }
        },
        "condition": {
          "$comment": "Optional: only eligible when condition evaluates true",
          "$ref": "condition.schema.json"
        }
      }
    }
  }
}